# Copy this file to .env for local runs. Never commit .env or real tokens.

# ─── Required Cloudflare accounts ─────────────────────────────────────────────
# Account IDs are not secrets, but keep client/account-specific values in .env.
CF_FROM_ACCOUNT_ID=source-account-id
CF_TO_ACCOUNT_ID=target-account-id

# Cloudflare API tokens are secrets. Create account-scoped tokens with the minimum
# read permissions on the source account and edit permissions on the target account.
CF_FROM_API_TOKEN=source-api-token
CF_TO_API_TOKEN=target-api-token

# ─── Optional zone/site migration ─────────────────────────────────────────────
# Required only for products such as dns, zone-settings, page-rules, rulesets,
# workers-routes, and custom-hostnames.
CF_FROM_ZONE_ID=source-zone-id
CF_TO_ZONE_ID=target-zone-id
CF_ZONE_NAME=example.com

# ─── Product selection and output ─────────────────────────────────────────────
CF_MIGRATE=images,stream
CF_MIGRATE_RETRY_FAILED=
CF_ASSET_DUMP_DIR=cloudflare-asset-dump
CF_MIGRATE_DRY_RUN=false

# ─── KV and R2 mappings ───────────────────────────────────────────────────────
# Use comma-separated source:target pairs. Use titles or IDs for KV namespaces.
CF_KV_NAMESPACE_MAP=source-kv:target-kv
CF_R2_BUCKET_MAP=source-bucket:target-bucket
# Shortcut when the source and target bucket names match.
CF_R2_BUCKET=

# Optional R2 metadata/access-key IDs. Do not put secret access keys here.
CF_FROM_R2_PARENT_ACCESS_KEY_ID=
CF_TO_R2_PARENT_ACCESS_KEY_ID=

# ─── Optional KV URL rewrites ─────────────────────────────────────────────────
CF_FROM_STREAM_CUSTOMER_CODE=source-stream-customer-code
CF_TO_STREAM_CUSTOMER_CODE=target-stream-customer-code
CF_FROM_IMAGES_ACCOUNT_HASH=source-images-account-hash
CF_TO_IMAGES_ACCOUNT_HASH=target-images-account-hash

# ─── Timeouts and retry tuning ────────────────────────────────────────────────
CF_STREAM_DOWNLOAD_READY_TIMEOUT_MS=1200000
CF_STREAM_DOWNLOAD_POLL_MS=5000
CF_STREAM_TRANSFER_TIMEOUT_MS=1800000
CF_MIGRATE_TRANSFER_TIMEOUT_MS=300000
CF_MIGRATE_MAX_RETRIES=8
CF_MIGRATE_RETRY_BASE_MS=1000
CF_MIGRATE_RETRY_MAX_MS=60000
CF_MIGRATE_REQUEST_TIMEOUT_MS=120000
