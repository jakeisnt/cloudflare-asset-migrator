# ─── Authentication ───────────────────────────────────────────────────────────
# No secret needed — @uln/auth 0.2.0 uses asymmetric ECDSA tokens.
# Public keys are fetched from auth.uln.industries/.well-known/jwk.json.

# ─── Cloudflare API (server-side, used by manage page server actions) ────────
# Required for video/photo uploads and fetching video metadata (aspect ratio).
# Create a Cloudflare custom API token at My Profile → API Tokens with:
#   Account → Cloudflare Stream → Edit
#   Account → Cloudflare Images → Edit
# Set it with: pnpm wrangler secret put CF_STREAM_API_TOKEN
# Named CF_STREAM_API_TOKEN (not CLOUDFLARE_API_TOKEN) to avoid colliding with
# wrangler's magic env var of the same name, which overrides wrangler's OAuth.
CF_STREAM_API_TOKEN=your-api-token
# If Wrangler cannot auto-detect the account, prefix secret writes with:
#   CLOUDFLARE_ACCOUNT_ID=your-account-id pnpm wrangler secret put CF_STREAM_API_TOKEN
# Set it with: pnpm wrangler secret put CLOUDFLARE_ACCOUNT_ID
CLOUDFLARE_ACCOUNT_ID=your-account-id

# ─── Cloudflare asset migration (local-only; used by pnpm migrate:cf-assets) ──
# Copy these to .env when moving Images, Stream, KV, and R2 between accounts.
CF_FROM_ACCOUNT_ID=source-account-id
CF_FROM_API_TOKEN=source-api-token
CF_TO_ACCOUNT_ID=target-account-id
CF_TO_API_TOKEN=target-api-token
CF_MIGRATE=images,stream,kv,r2
CF_KV_NAMESPACE_MAP=ERIK_HE_KV:ERIK_HE_KV
CF_R2_BUCKET=erik-he

# ─── Site URL (used for sitemap, canonical URLs, OG tags, auth callback) ─────
# Fallback in src/env.ts is https://erik-he.uln.industries when unset — override
# with your public origin (e.g. https://erikhe.com) in production and in Worker vars.
SITE_URL=https://erikhe.com

# ─── Cloudflare Images (client-side, used for imagedelivery.net URLs) ────────
# Found in: Cloudflare dashboard → Images → Overview → "Account Hash"
# Set in wrangler.jsonc as a worker var (NEXT_PUBLIC_CLOUDFLARE_IMAGES_ACCOUNT_HASH).
# No env var needed locally unless overriding.

# ─── Cloudflare KV ───────────────────────────────────────────────────────────
# KV is NOT configured via env vars. It's a Worker runtime binding defined in
# wrangler.jsonc (binding: ERIK_HE_KV, namespace ID: e2eb769208e74b6aa4dd914180b8b9cf).
# The code accesses it via `import { env } from "cloudflare:workers"`.
# No env var needed — the Workers platform injects the binding at runtime.

# ─── Cloudflare Stream delivery (public customer code) ───────────────────────
# Used to derive:
#   customer-${NEXT_PUBLIC_CLOUDFLARE_CUSTOMER_CODE}.cloudflarestream.com
# for HLS manifests and thumbnails.
# Defaults to nuayb0iz1dy4986k in src/env.ts if unset.
NEXT_PUBLIC_CLOUDFLARE_CUSTOMER_CODE=nuayb0iz1dy4986k
